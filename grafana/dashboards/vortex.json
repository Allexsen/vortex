    {
      "type": "timeseries",
      "title": "Messages Consumed",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(vortex_embedder_messages_processed_total[5m])",
          "legendFormat": "{{status}}",
