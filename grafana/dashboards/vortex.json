      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vortex_search_embed_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vortex_search_embed_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Embedder",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Chunks Encoded",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(vortex_embedder_chunks_encoded_total[5m])",
          "legendFormat": "chunks",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Message Process Latency",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vortex_embedder_message_process_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vortex_embedder_message_process_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
