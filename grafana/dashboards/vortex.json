{
  "uid": "vortex-overview",
  "title": "Vortex Overview",
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Crawler",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Crawl Rate",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(vortex_worker_pages_crawled_total[1m])",
          "legendFormat": "pages/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Discovery Rate",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(vortex_worker_urls_discovered_total[1m])",
          "legendFormat": "urls/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tasks by Status",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(vortex_worker_tasks_processed_total[1m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Page Process Latency",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vortex_worker_page_process_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vortex_worker_page_process_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cooldown Republishes",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(vortex_worker_cooldown_republished_total[1m])",
          "legendFormat": "republishes/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate Limit Denials",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(vortex_ratelimit_limited_total[1m])",
          "legendFormat": "denied/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Fetcher",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Fetch Errors by Type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(vortex_fetcher_errors_total[1m])",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Fetch Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vortex_fetcher_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vortex_fetcher_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "Search",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Search Requests",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(vortex_search_requests_total[5m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Search Latency",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(vortex_search_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(vortex_search_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
